    "/api/v1/accounts": {
      "post": {
        "description": "Creates an NFC-backed account for a user. Requires an admin API token.",
        "operationId": "AccountsController_createAccount_v1",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateAccountDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Account created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateAccountResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Create account",
        "tags": ["Accounts"]
      },
      "get": {
        "description": "Returns a paginated list of accounts with each account owner (user) summary. Admins may filter by owner user id, owner user type, lock state, and a case-insensitive search on NFC UID or owner name fields.",
        "operationId": "AccountsController_listAccounts_v1",
        "parameters": [
          {
            "name": "userId",
            "required": false,
            "in": "query",
            "description": "Return only accounts owned by this user.",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "name": "ownerType",
            "required": false,
            "in": "query",
            "description": "Return only accounts whose owner has this user type.",
            "schema": {
              "type": "string",
              "enum": ["user", "provider", "admin"]
            }
          },
          {
            "name": "isLocked",
            "required": false,
            "in": "query",
            "description": "Return only locked (true) or unlocked (false) accounts.",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "search",
            "required": false,
            "in": "query",
            "description": "Case-insensitive substring match on NFC card UID, owner display name, or owner login name (userName).",
            "schema": {
              "maxLength": 128,
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "Page size (default 50, max 100).",
            "schema": {
              "default": 50,
              "type": "number"
            }
          },
          {
            "name": "offset",
            "required": false,
            "in": "query",
            "description": "Number of rows to skip (pagination).",
            "schema": {
              "default": 0,
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Accounts retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ListAccountsResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List accounts",
        "tags": ["Accounts"]
      }
    },
    "/api/v1/accounts/{accountId}/transactions": {
      "get": {
        "description": "Returns transactions where the account is the payer, payee, or mint recipient. The account owner or an admin may call this.",
        "operationId": "AccountsController_getAccountTransactions_v1",
        "parameters": [
          {
            "name": "accountId",
            "required": true,
            "in": "path",
            "description": "Account ID",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "description": "How many transactions to return (default 10, max 100).",
            "schema": {
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transactions retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TransactionResponseDto"
                  }
                }
              }
            }
          },
          "403": {
            "description": "Caller is not the account owner or an admin"
          },
          "404": {
            "description": "Account not found"
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "List account transactions",
        "tags": ["Accounts"]
      }
    },
