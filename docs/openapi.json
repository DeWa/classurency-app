  "info": {
    "title": "Classurency API",
    "description": "API documentation for the Classurency backend.",
    "version": "0.0.1",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "token",
        "type": "http"
      }
    },
    "schemas": {
      "CreateUserDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Ada Lovelace",
            "maxLength": 128,
            "description": "User display name."
          },
          "userName": {
            "type": "string",
            "description": "User username (letters, digits, - _ + only; no spaces)",
            "maxLength": 128,
            "pattern": "^[-a-zA-Z0-9_+]+$"
          }
        },
        "required": ["name", "userName"]
      },
      "CreateUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "name": {
            "type": "string",
            "description": "User name"
          },
          "password": {
            "type": "string",
            "description": "User password"
          },
          "type": {
            "type": "string",
            "description": "User type"
          }
        },
        "required": ["id", "name", "password", "type"]
      },
      "ListUserItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "userName": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["user", "provider", "admin"]
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": ["id", "name", "userName", "type", "createdAt", "updatedAt"]
      },
      "ListUsersResponseDto": {
        "type": "object",
        "properties": {
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ListUserItemDto"
            }
          },
          "total": {
            "type": "number",
            "description": "Total rows matching the filters (ignoring limit/offset)."
          }
        },
        "required": ["users", "total"]
      },
      "UpdateUserRequestDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Ada Lovelace",
            "maxLength": 128,
            "description": "User display name."
          },
          "password": {
            "type": "string",
            "example": "a-long-random-secret",
            "minLength": 6,
            "maxLength": 128,
            "description": "Account password for API login (stored with Argon2id; distinct from the generated card PIN)."
          },
          "type": {
            "type": "string",
            "example": "admin",
            "enum": ["user", "provider", "admin"],
            "description": "User type."
          }
        },
        "required": ["name", "password", "type"]
      },
      "UpdateUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "name": {
            "type": "string",
            "description": "User name"
          },
          "type": {
            "type": "string",
            "description": "User type"
          }
        },
        "required": ["id", "name", "type"]
      },
      "UserAccountSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "nfcCardUid": {
            "type": "object",
            "nullable": true,
            "description": "NFC card UID when the account is bound to a card."
          },
          "publicKeyHex": {
            "type": "string",
            "description": "Account public key (hex)."
          },
          "balance": {
            "type": "number",
            "description": "Current balance."
          },
          "isLocked": {
            "type": "boolean",
            "description": "Whether the account is locked."
          },
          "createdAt": {
            "format": "date-time",
            "type": "string"
          },
          "updatedAt": {
            "format": "date-time",
            "type": "string"
          }
        },
        "required": [
          "id",
          "nfcCardUid",
          "publicKeyHex",
          "balance",
          "isLocked",
          "createdAt",
          "updatedAt"
        ]
      },
      "GetUserResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "User ID"
          },
          "name": {
            "type": "string",
            "description": "User name"
          },
          "type": {
            "type": "string",
            "description": "User type"
          },
          "providerId": {
            "type": "string",
            "format": "uuid",
            "description": "Item provider id when the user type is provider and an item provider exists."
          },
          "accounts": {
            "description": "Included when the request uses includeAccounts=true.",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserAccountSummaryDto"
            }
          }
        },
        "required": ["id", "name", "type"]
      },
      "RequestTokenDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "example": "3fa85f64-5717-4562-b3fc-2c963f66afa6",
            "format": "uuid",
            "description": "Target user id."
          },
          "privilege": {
            "type": "string",
            "example": "provider",
            "enum": ["admin", "provider", "user"],
