            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Update a user",
        "tags": ["Users"]
      },
      "get": {
        "description": "Get a user with the given ID",
        "operationId": "UsersController_getUser_v1",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "description": "User ID",
            "schema": {
              "format": "uuid",
              "type": "string"
            }
          },
          {
            "name": "includeAccounts",
            "required": false,
            "in": "query",
            "description": "When true, includes each account id, balance, lock state, public key, and NFC UID (no secrets).",
            "schema": {
              "type": "boolean"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User retrieved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetUserResponseDto"
                }
              }
            }
          }
        },
        "security": [
          {
            "bearer": []
          }
        ],
        "summary": "Get a user",
        "tags": ["Users"]
      }
    },
